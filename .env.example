# URL del servidor Ollama (en la Mac: http://localhost:11434;
# desde otra máquina de la tailnet: http://100.83.237.84:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Modelos de Ollama (hace falta: ollama pull bge-m3)
# bge-m3 es multilingüe (100+ idiomas) y hace recuperación cross-lingual: una
# pregunta en español encuentra pasajes en portugués o inglés. nomic-embed-text
# es más ligero pero prácticamente monolingüe inglés.
# Al cambiar de modelo, `paperlab process` recalcula los embeddings obsoletos.
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=bge-m3

# Contexto máximo para generación (tokens). 8192 es seguro en 16 GB de RAM.
OLLAMA_NUM_CTX=8192

# Email de contacto: OpenAlex (polite pool) y Unpaywall lo requieren.
CONTACT_EMAIL=tu-email@ejemplo.com

# Directorio de datos (DB SQLite y PDFs). Por defecto: ./data
# PAPERLAB_DATA_DIR=./data

# Directorio de PDFs aparte del resto de datos (si prefieres un volumen montado).
# La base SQLite NO va aquí: se queda en PAPERLAB_DATA_DIR (local).
# Tras cambiarlo, `paperlab relocate-pdfs` mueve los PDFs ya descargados.
# PAPERLAB_PDF_DIR=/Volumes/nas/paperlab-pdfs

# NAS personal (SRC Cloud): respaldo de PDFs vía su API WebDAV con
# `paperlab sync-nas` o el botón «☁ PDFs al NAS». Usa tu usuario del NAS.
# NAS_BASE_URL=http://localhost:8000
# NAS_USERNAME=tu-usuario
# NAS_PASSWORD=tu-contraseña
# NAS_PDF_DIR=paperlab/pdfs

# Vault de Obsidian donde `paperlab export-obsidian` escribe las notas
# (crea <vault>/Papers/ y <vault>/Papers/MOC/).
# OBSIDIAN_VAULT_PATH=~/Obsidian/Investigación
