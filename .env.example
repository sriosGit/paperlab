# URL del servidor Ollama (en la Mac: http://localhost:11434;
# desde otra máquina de la tailnet: http://100.83.237.84:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Modelos de Ollama (hace falta: ollama pull nomic-embed-text)
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Contexto máximo para generación (tokens). 8192 es seguro en 16 GB de RAM.
OLLAMA_NUM_CTX=8192

# Email de contacto: OpenAlex (polite pool) y Unpaywall lo requieren.
CONTACT_EMAIL=tu-email@ejemplo.com

# Directorio de datos (DB SQLite y PDFs). Por defecto: ./data
# PAPERLAB_DATA_DIR=./data

# Vault de Obsidian donde `paperlab export-obsidian` escribe las notas
# (crea <vault>/Papers/ y <vault>/Papers/MOC/).
# OBSIDIAN_VAULT_PATH=~/Obsidian/Investigación
